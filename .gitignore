# .gitignore — Thermal VO₂ Neuristor Network
# ─────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
lib/
lib64/
parts/
var/
*.manifest
*.spec

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data ──────────────────────────────────────────────────────────────────────
# Raw MNIST data (auto-downloaded by sklearn; do not commit)
data/raw/
data/processed/
# Scikit-learn OpenML cache
~/scikit_learn_data/

# ── Results & outputs (large files — store in Zenodo/Figshare, not Git) ───────
results/model.pkl
results/figures/*.png
results/figures/*.pdf
results/*.csv
results/*.npz

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Linux ─────────────────────────────────────────────────────────────────────
*~
.nfs*

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.project
.pydevproject
.spyderproject
.spyproject
.ropeproject

# ── Type checking / linting ───────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ── Documentation build ───────────────────────────────────────────────────────
docs/_build/
docs/api/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
.hypothesis/
.pytest_cache/
coverage.xml
.coverage
htmlcov/
